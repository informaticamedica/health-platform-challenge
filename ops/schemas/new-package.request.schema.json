{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "new-package.request.schema.json",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "kind": { "type": "string", "enum": ["library", "service", "shared"] },
    "scope": { "type": "string" }
  }
}
