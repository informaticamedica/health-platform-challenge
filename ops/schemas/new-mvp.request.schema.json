{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "new-mvp.request.schema.json",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "scope": { "type": "string", "enum": ["front", "back", "ambos"] },
    "templateFront": { "type": "string" },
    "templateBack": { "type": "string" },
    "packagesFront": { "type": "array", "items": { "type": "string" } },
    "packagesBack": { "type": "array", "items": { "type": "string" } },
    "db": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "name": { "type": "string" },
        "migrateCommand": { "type": "string" }
      }
    },
    "testing": { "type": "string", "enum": ["unit", "integration", "ambos"] }
  }
}
