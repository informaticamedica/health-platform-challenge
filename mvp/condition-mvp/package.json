{
  "name": "@platform/condition-mvp",
  "private": true,
  "scripts": {
    "install:front": "npm install --prefix ./condition-mvp-front",
    "install:back": "npm install --prefix ./condition-mvp-back",
    "install:all": "npm run install:front && npm run install:back",
    "build:front": "npm run build --prefix ./condition-mvp-front",
    "build:back": "npm run build --prefix ./condition-mvp-back",
    "build:all": "npm run build:front && npm run build:back",
    "dev:front": "npm run dev --prefix ./condition-mvp-front",
    "dev:back": "npm run dev --prefix ./condition-mvp-back",
    "db:migrate": "node ./condition-mvp-back/scripts/run-migrations.mjs"
  }
}
