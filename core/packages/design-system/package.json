{
  "name": "@platform/design-system",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles/theme.css": "./dist/styles/theme.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "build-storybook": "storybook build",
    "test": "vitest run --config vitest.config.ts --project=unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --project=unit --coverage",
    "test:storybook": "vitest run --config vitest.config.ts --project=storybook",
    "clean": "node scripts/clean.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "postcss": "^8.4.49",
    "storybook": "^10.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
