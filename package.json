{
  "name": "platform-challenge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "core/packages/*",
    "core/templates/*",
    "mvp/producto1/producto1-front",
    "mvp/producto1/producto1-back",
    "infra/local/postgres/soc-db-source"
  ],
  "scripts": {
    "dev:front": "npm run dev --workspace ./core/templates/react-app-boilerplate",
    "dev:back": "npm run dev --workspace ./core/templates/node-api-boilerplate",
    "dev:ds": "npm run dev --workspace ./core/packages/design-system",
    "build:ds": "npm run build --workspace ./core/packages/design-system",
    "db:up": "npm run up --workspace ./infra/local/postgres/soc-db-source",
    "db:down": "npm run down --workspace ./infra/local/postgres/soc-db-source",
    "db:reset": "npm run reset --workspace ./infra/local/postgres/soc-db-source"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5"
  }
}
