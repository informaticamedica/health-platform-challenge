{
  "name": "platform-challenge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "core/packages/*",
    "core/templates/*",
    "mvp/*/*-front",
    "mvp/*/*-back",
    "infra/local/postgres/soc-db-source"
  ],
  "scripts": {
    "dev:front": "pnpm --filter ./core/templates/react-app-boilerplate run dev",
    "dev:back": "pnpm --filter ./core/templates/node-api-boilerplate run dev",
    "dev:ds": "pnpm --filter ./core/packages/design-system run dev",
    "build:ds": "pnpm --filter ./core/packages/design-system run build",
    "db:up": "pnpm --filter ./infra/local/postgres/soc-db-source run up",
    "db:down": "pnpm --filter ./infra/local/postgres/soc-db-source run down",
    "db:reset": "pnpm --filter ./infra/local/postgres/soc-db-source run reset"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5"
  }
}
